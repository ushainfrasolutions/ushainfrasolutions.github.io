    "VISION & MISSION.html": {
      "settings": {
        "meta_descr": "BUSINESS STRATEGY\nUsha infra solutions claims to be one of the most reliable suppliers of VARIOUS ENGINEERING PRODUCTS in International market through their dynamic business strategy, driven by ethos of sustainability and transparency, The company has established ultra modern manufacturing facilities to achieve the requirements of our valuable global customers and world class quality. We Devise our strategies and implement our actions the motto of NO COMPROMISE WITH THE QUALITY. Our mission is to create our presence in every part of the world with our reliable commitments, unmatched experience and quality services.",
        "title": "VISION &amp; MISSION",
        "order": 3
      },
      "components": [
        {
          "alias": false,
          "_styles": {
